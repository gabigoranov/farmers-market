@using Market.Models.DTO
@using Newtonsoft.Json
@model List<OrderDTO>
@{
    ViewData["Title"] = "Statistics";
}

<section class="stats-section">
    <div class="stats-container">
        <canvas id="pastIncomeChart"></canvas>
    </div>
    <div class="stats-container">
        <canvas id="productPerformanceChart"></canvas>
    </div>
    <div class="stats-container" >
        <canvas id="orderBreakdownChart"></canvas>
    </div>
    <div class="stats-container">
        <canvas id="salesTrendChart"></canvas>
    </div>
    <div class="stats-container">
        <canvas id="topSellersChart"></canvas>
    </div>
    <div class="stats-container">
        <canvas id="revenueGrowthChart"></canvas>
    </div>
</section>


<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<script src="~/js/site.js"></script>

<script>
    document.addEventListener('DOMContentLoaded', function () {
        // Serialize the order model from C# to JavaScript
        var orderData = @Html.Raw(Json.Serialize(Model));

        // Prepare the data object that loadStatistics expects
        var data = {
            income: {
                labels: ["January", "February", "March"],  // Example, replace with your data
                values: [5000, 7000, 6000],  // Example, replace with your data
                total: 18000  // Example, replace with your data
            }
        };

        // Call the loadStatistics function
        loadStatistics(data, '/api/product');  // Pass any necessary API URL if needed
    });
</script>
