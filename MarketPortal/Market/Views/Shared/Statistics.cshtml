@using Market.Models.DTO
@model List<OrderDTO>
@{
    ViewData["Title"] = "Statistics";
}

<section class="stats-section">
    <div class="stats-container">
        <canvas id="pastIncomeChart"></canvas>
    </div>
    <div class="stats-container">
        <canvas id="productPerformanceChart"></canvas>
    </div>
    <div class="stats-container" >
        <canvas id="orderBreakdownChart"></canvas>
    </div>
    <div class="stats-container">
        <canvas id="salesTrendChart"></canvas>
    </div>
    <div class="stats-container">
        <canvas id="topSellersChart"></canvas>
    </div>
    <div class="stats-container">
        <canvas id="revenueGrowthChart"></canvas>
    </div>
</section>


<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<script>

    var ctx = document.getElementById('pastIncomeChart').getContext('2d');
    var totalIncome = @Html.Raw(Json.Serialize(Model.Where(x => x.IsAccepted).Select(m => m.Price).Sum().ToString()));
    var incomeChart = new Chart(ctx, {
        type: 'line',
        data: {
            labels: @Html.Raw(Json.Serialize(Model.Where(x => x.IsAccepted).Select(m => m.DateOrdered.ToString("yyyy-MM-dd")))),
            datasets: [{
                label: `Orders, Income: ${totalIncome}`,
                data: @Html.Raw(Json.Serialize(Model.Where(x => x.IsAccepted).Select(m => m.Price))),
                backgroundColor: 'rgba(75, 192, 192, 0.2)',
                borderColor: 'rgba(75, 192, 192, 1)',
                borderWidth: 1
            }]
        },
        options: {
            scales: {
                x: { display: true },
                y: { display: true }
            }
        }
    });


</script>
<script>
    let url = `https://farmers-api.runasp.net/api/users/{@Model[0].SellerId}/offers`;
    let titles = [];
    let unitsSold = [];

    console.log(url);
    fetch(url)  // Example API URL for fetching the offers
        .then(response => response.json())  // Parse the JSON response
        .then(data => {
            // Use map() to extract the title and units_sold from each offer
            titles = data.map(offer => offer.title);
            unitsSold = data.map(offer => offer.units_sold);

            // Output the lists of titles and units sold
            console.log('Titles:', titles);
            console.log('Units Sold:', unitsSold);
        })
        .catch(error => console.error('Error fetching data:', error));
    const productData = {
        labels: titles, // Product names
        datasets: [{
            label: 'Units Sold',
            data: unitsSold, // Units sold for each product
            backgroundColor: [
                'rgba(255, 99, 132, 0.7)',
                'rgba(54, 162, 235, 0.7)',
                'rgba(255, 206, 86, 0.7)',
                'rgba(75, 192, 192, 0.7)',
                'rgba(153, 102, 255, 0.7)',
                'rgba(255, 159, 64, 0.7)'
            ],
            borderColor: [
                'rgba(255, 99, 132, 1)',
                'rgba(54, 162, 235, 1)',
                'rgba(255, 206, 86, 1)',
                'rgba(75, 192, 192, 1)',
                'rgba(153, 102, 255, 1)',
                'rgba(255, 159, 64, 1)'
            ],
            borderWidth: 1
        }]
    };

    // Configuration options
    const config = {
        type: 'bar',
        data: productData,
        options: {
            responsive: true,
            plugins: {
                legend: {
                    position: 'top',
                },
                title: {
                    display: true,
                    text: 'Product Performance - Units Sold'
                }
            },
            scales: {
                y: {
                    beginAtZero: true,
                    title: {
                        display: true,
                        text: 'Units Sold'
                    }
                },
                x: {
                    title: {
                        display: true,
                        text: 'Products'
                    }
                }
            }
        }
    };

    // Render the chart
    const ctx2 = document.getElementById('productPerformanceChart').getContext('2d');
    new Chart(ctx2, config);
</script>
<script>
    // Sample data for the chart
